---
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Valdemar Studio · Marketing Digital para marcas de salud y fitness</title>
  <meta name="description" content="Gerente de marketing digital especializado en salud y bienestar en Mexicali. Manejo de redes sociales, sitio web, Google Maps, Rappi y más." />
  <link rel="icon" href="/logo.png" type="image/png" />
</head>
<body>

  <!-- NAV -->
  <nav>
    <div class="container">
      <a href="#" class="logo">
        <img src="/logo.png" alt="Valdemar Studio" class="logo-img" />
        <span class="logo-text">Valdemar<span class="accent">.</span>Studio</span>
      </a>
      <ul class="nav-links">
        <li><a href="#sobre-mi">Sobre mí</a></li>
        <li><a href="#aliados">Aliados</a></li>
        <li><a href="#servicios">Servicios</a></li>
        <li><a href="#contacto">Contacto</a></li>
      </ul>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="container">
      <img src="/logo.png" alt="Valdemar Studio" class="hero-logo" />
      <h1>Marketing digital para marcas de <span class="accent">salud y bienestar</span></h1>
      <p>Gerente de marketing digital especializado en el sector salud. Me encargo de todo: redes sociales, sitio web, Google Maps, Rappi y más — desde Mexicali.</p>
      <div class="hero-actions">
        <a href="#contacto" class="btn">Trabajemos juntos</a>
        <a href="#servicios" class="btn btn-outline">Ver servicios</a>
      </div>
    </div>
  </section>

  <!-- SOBRE MÍ -->
  <section id="sobre-mi">
    <div class="container">
      <div class="about">
        <div class="avatar-wrap reveal">
          <div class="avatar">V</div>
        </div>
        <div class="about-content">
          <span class="section-label reveal">Sobre mí</span>
          <h2 class="reveal reveal-delay-1">Soy Valdemar</h2>
          <p class="reveal reveal-delay-2">Gerente de marketing digital especializado en marcas del sector salud y bienestar. Me encargo de construir y escalar la presencia digital de cada cliente con una estrategia integral y resultados medibles.</p>
          <p class="reveal reveal-delay-3">Trabajo desde Mexicali gestionando desde cero el ecosistema digital de marcas locales: sus redes sociales, su reputación en Google, su presencia en plataformas de delivery y su comunicación con clientes.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ALIADOS -->
  <section id="aliados">
    <div class="container">
      <span class="section-label reveal">Aliado estratégico</span>
      <h2 class="reveal reveal-delay-1">La marca que confía en mi trabajo</h2>
      <p class="reveal reveal-delay-2">Gestiono de forma integral el ecosistema digital de Go Pharmacy, una farmacia local con visión de crecimiento.</p>

      <div class="ally-featured reveal reveal-delay-3">
        <div class="ally-featured-logo">
          <img src="/go-pharmacy.png" alt="Go Pharmacy" />
        </div>
        <div class="ally-featured-content">
          <span class="ally-badge">Farmacia · Mexicali</span>
          <h3>Go Pharmacy</h3>
          <p>Farmacia local con enfoque en salud preventiva y atención personalizada. Me encargo de todo su ecosistema digital para conectarlos con más clientes en Mexicali.</p>
          <div class="ally-roles">
            <span class="ally-role">Marketing Digital</span>
            <span class="ally-role">Redes Sociales</span>
            <span class="ally-role">Sitio Web</span>
            <span class="ally-role">Google Maps</span>
            <span class="ally-role">Rappi</span>
            <span class="ally-role">Contenido Audiovisual</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICIOS -->
  <section id="servicios">
    <div class="container">
      <span class="section-label reveal">Servicios</span>
      <h2 class="reveal reveal-delay-1">Gestión digital integral</h2>
      <p class="reveal reveal-delay-2">Me encargo de todo el ecosistema digital de tu marca, de principio a fin.</p>
      <div class="services-grid">
        <div class="service-card reveal reveal-delay-1">
          <div class="service-icon">📱</div>
          <h3>Redes Sociales</h3>
          <p>Gestión y crecimiento de Instagram, TikTok, Facebook y YouTube con contenido audiovisual profesional.</p>
        </div>
        <div class="service-card reveal reveal-delay-2">
          <div class="service-icon">🌐</div>
          <h3>Sitio Web</h3>
          <p>Diseño, desarrollo y mantenimiento de sitios web optimizados para convertir visitantes en clientes.</p>
        </div>
        <div class="service-card reveal reveal-delay-3">
          <div class="service-icon">📍</div>
          <h3>Google Maps</h3>
          <p>Optimización de perfil de Google Business, reputación y posicionamiento local.</p>
        </div>
        <div class="service-card reveal reveal-delay-4">
          <div class="service-icon">🛵</div>
          <h3>Rappi & Delivery</h3>
          <p>Gestión de cuenta en plataformas de delivery para maximizar ventas y visibilidad.</p>
        </div>
        <div class="service-card reveal reveal-delay-1">
          <div class="service-icon">🎥</div>
          <h3>Producción Audiovisual</h3>
          <p>Grabación, edición y publicación de contenido en video con equipo 4K profesional.</p>
        </div>
        <div class="service-card reveal reveal-delay-2">
          <div class="service-icon">📊</div>
          <h3>Métricas & Reportes</h3>
          <p>Seguimiento de resultados, análisis de datos y reportes mensuales de cada plataforma.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CONTACTO -->
  <section id="contacto" class="contact">
    <div class="container">
      <span class="section-label reveal">Contacto</span>
      <h2 class="reveal reveal-delay-1">Hablemos de tu marca</h2>
      <p class="reveal reveal-delay-2">Si tu negocio pertenece al sector salud o bienestar y quieres llevar tu presencia digital al siguiente nivel, escríbeme.</p>
      <div class="social-links reveal reveal-delay-3">
        <a href="https://instagram.com/soy.valdemar97" class="social-link" target="_blank" rel="noopener">📷 Instagram</a>
        <a href="https://youtube.com/@soy.valdemar97" class="social-link" target="_blank" rel="noopener">▶️ YouTube</a>
        <a href="https://tiktok.com/@soy.valdemar97" class="social-link" target="_blank" rel="noopener">🎵 TikTok</a>
        <a href="https://facebook.com/soy.valdemar97" class="social-link" target="_blank" rel="noopener">👥 Facebook</a>
      </div>
    </div>
  </section>

  <footer>
    <div class="container">
      © 2026 Valdemar<span class="accent">.</span>Studio · Mexicali, México
    </div>
  </footer>

  <!-- SCROLL ANIMATIONS -->
  <script>
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    }, {
      threshold: 0.12,
      rootMargin: '0px 0px -40px 0px'
    });

    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
  </script>

</body>
</html>
